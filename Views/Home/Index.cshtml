@{
    ViewData["Title"] = "Inicio";
}

<div class="container py-5">

    <div class="row align-items-center mb-5">
        <div class="col-lg-7">
            <span class="badge bg-primary-subtle text-primary border border-primary-subtle mb-3 px-3 py-2">
                Marketplace Automation
            </span>

            <h1 class="display-5 fw-bold mb-3">
                Automatiza productos desde eBay, Amazon y Mercado Libre
            </h1>

            <p class="lead text-muted mb-4">
                Centraliza productos, revisa precio y stock, prepara publicaciones y sincroniza información hacia Mercado Libre.
            </p>

            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Products" asp-action="Index" class="btn btn-primary btn-lg">
                    Ver productos
                </a>

                <a asp-controller="Products" asp-action="CreateFromUrl" class="btn btn-outline-dark btn-lg">
                    Agregar producto por link
                </a>

                <a asp-controller="MercadoLibre" asp-action="Status" class="btn btn-outline-success btn-lg">
                    Estado Mercado Libre
                </a>
            </div>
        </div>

        <div class="col-lg-5 mt-4 mt-lg-0">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Flujo actual</h5>

                    <div class="d-flex align-items-start mb-3">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width:35px;height:35px;">
                            1
                        </div>
                        <div>
                            <strong>Captura URL</strong>
                            <div class="text-muted small">Pega un link de eBay, Amazon o Mercado Libre.</div>
                        </div>
                    </div>

                    <div class="d-flex align-items-start mb-3">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width:35px;height:35px;">
                            2
                        </div>
                        <div>
                            <strong>Extrae información</strong>
                            <div class="text-muted small">Obtiene título, precio, stock, imagen, marca y modelo cuando la API lo permite.</div>
                        </div>
                    </div>

                    <div class="d-flex align-items-start mb-3">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width:35px;height:35px;">
                            3
                        </div>
                        <div>
                            <strong>Revisión manual</strong>
                            <div class="text-muted small">Ajustas categoría, atributos y datos requeridos por Mercado Libre.</div>
                        </div>
                    </div>

                    <div class="d-flex align-items-start">
                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width:35px;height:35px;">
                            4
                        </div>
                        <div>
                            <strong>Publicación</strong>
                            <div class="text-muted small">Se envía a Mercado Libre usando tu token conectado.</div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="fs-2 mb-3">🔎</div>
                    <h5 class="fw-bold">Detección automática</h5>
                    <p class="text-muted mb-0">
                        El sistema identifica si el producto viene de eBay, Amazon o Mercado Libre usando la URL origen.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="fs-2 mb-3">📦</div>
                    <h5 class="fw-bold">Stock y precio</h5>
                    <p class="text-muted mb-0">
                        El objetivo principal es monitorear disponibilidad, precio fuente y estado del producto.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="fs-2 mb-3">🛒</div>
                    <h5 class="fw-bold">Mercado Libre</h5>
                    <p class="text-muted mb-0">
                        Prepara publicaciones con categoría, atributos, imagen, precio, stock y condición.
                    </p>
                </div>
            </div>
        </div>

    </div>

    <div class="card border-0 shadow-sm rounded-4 mt-5">
        <div class="card-body p-4">
            <h4 class="fw-bold mb-3">Estado del proyecto</h4>

            <div class="row g-3">
                <div class="col-md-3">
                    <div class="p-3 bg-success-subtle border border-success-subtle rounded-3">
                        <strong class="text-success">Listo</strong>
                        <div class="small text-muted">Conexión Mercado Libre</div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="p-3 bg-success-subtle border border-success-subtle rounded-3">
                        <strong class="text-success">Listo</strong>
                        <div class="small text-muted">Extracción eBay inicial</div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="p-3 bg-warning-subtle border border-warning-subtle rounded-3">
                        <strong class="text-warning">Pendiente</strong>
                        <div class="small text-muted">Amazon Product Advertising API</div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="p-3 bg-warning-subtle border border-warning-subtle rounded-3">
                        <strong class="text-warning">Pendiente</strong>
                        <div class="small text-muted">Refresh automático</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>