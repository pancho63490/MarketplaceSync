@model MarketplaceSync.Web.ViewModels.CreateProductFromUrlViewModel

@{
    ViewData["Title"] = "Agregar producto por link";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h1 class="fw-bold mb-2">Agregar producto por link</h1>
                    <p class="text-muted mb-4">
                        Pega un link de Amazon, eBay o Mercado Libre. El sistema detectará el marketplace y guardará el producto como borrador.
                    </p>

                    <form asp-action="CreateFromUrl" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="SourceUrl" class="form-label fw-semibold"></label>
                            <input asp-for="SourceUrl" class="form-control form-control-lg" placeholder="https://www.amazon.com.mx/dp/..." />
                            <span asp-validation-for="SourceUrl" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                Analizar y guardar borrador
                            </button>

                            <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">
                                Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="alert alert-info mt-4">
                <strong>Nota:</strong> por ahora se guardará como borrador. Después conectaremos las APIs de Amazon/eBay para llenar título, precio, stock e imágenes automáticamente.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}