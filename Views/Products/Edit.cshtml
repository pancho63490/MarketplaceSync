@model MarketplaceSync.Web.Models.Product

@{
    ViewData["Title"] = "Editar producto";
}

<div class="container mt-4 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-1">Editar producto</h1>
            <p class="text-muted mb-0">Revisa la información importada antes de publicar en Mercado Libre.</p>
        </div>

        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">
            Volver a productos
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

    <div class="row g-4">

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">

                    <h5 class="fw-bold mb-3">Vista rápida</h5>

                    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl"
                             class="img-fluid rounded border mb-3"
                             style="max-height: 260px; object-fit: contain; width: 100%;"
                             alt="Imagen producto" />
                    }
                    else
                    {
                        <div class="bg-light border rounded d-flex align-items-center justify-content-center mb-3"
                             style="height: 220px;">
                            <span class="text-muted">Sin imagen</span>
                        </div>
                    }

                    <div class="mb-2">
                        <span class="badge bg-dark">@Model.SourceMarketplace</span>
                        <span class="badge bg-warning text-dark">@Model.Status</span>
                    </div>

                    <p class="mb-1">
                        <strong>ID:</strong> @Model.Id
                    </p>

                    <p class="mb-1">
                        <strong>Source ID:</strong> @(Model.SourceProductId ?? "N/A")
                    </p>

                    <p class="mb-1">
                        <strong>Última revisión:</strong>
                        @(Model.LastSourceCheckAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "N/A")
                    </p>

                    @if (!string.IsNullOrWhiteSpace(Model.SourceUrl))
                    {
                        <a href="@Model.SourceUrl" target="_blank" class="btn btn-sm btn-outline-primary mt-2 w-100">
                            Abrir producto original
                        </a>
                    }

                    <form asp-controller="Products"
                          asp-action="PrepareForMercadoLibre"
                          asp-route-id="@Model.Id"
                          method="post"
                          class="mt-3">
                        @Html.AntiForgeryToken()

                        <button type="submit" class="btn btn-success w-100">
                            Preparar para Mercado Libre
                        </button>
                    </form>

                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <form asp-controller="Products"
      asp-action="RefreshSource"
      asp-route-id="@Model.Id"
      method="post"
      class="mt-3">
    @Html.AntiForgeryToken()

    <button type="submit" class="btn btn-outline-primary w-100">
        Refrescar información fuente
    </button>
</form>
            <form asp-controller="Products" asp-action="Edit" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="SourceUrl" />
                <input type="hidden" asp-for="SourceMarketplace" />
                <input type="hidden" asp-for="SourceProductId" />
                <input type="hidden" asp-for="CreatedAt" />
                <input type="hidden" asp-for="LastSourceCheckAt" />
                <input type="hidden" asp-for="MercadoLibreItemId" />
                <input type="hidden" asp-for="MercadoLibrePermalink" />
                <input type="hidden" asp-for="MercadoLibreStatus" />
                <input type="hidden" asp-for="MercadoLibrePublishedAt" />

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="fw-bold mb-0">Información importada</h5>
                    </div>

                    <div class="card-body">

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-semibold">Título</label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold">Descripción</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Brand" class="form-label fw-semibold">Marca</label>
                                <input asp-for="Brand" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Model" class="form-label fw-semibold">Modelo</label>
                                <input asp-for="Model" class="form-control" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ImageUrl" class="form-label fw-semibold">Imagen URL</label>
                            <input asp-for="ImageUrl" class="form-control" />
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="SourcePrice" class="form-label fw-semibold">Precio fuente</label>
                                <input asp-for="SourcePrice" class="form-control" type="number" step="0.01" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="SourceCurrency" class="form-label fw-semibold">Moneda fuente</label>
                                <input asp-for="SourceCurrency" class="form-control" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="SourceStock" class="form-label fw-semibold">Stock fuente</label>
                                <input asp-for="SourceStock" class="form-control" type="number" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="SourceStatus" class="form-label fw-semibold">Status fuente</label>
                                <input asp-for="SourceStatus" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="SourceAvailabilityText" class="form-label fw-semibold">Texto disponibilidad</label>
                                <input asp-for="SourceAvailabilityText" class="form-control" />
                            </div>
                        </div>

                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="fw-bold mb-0">Datos para Mercado Libre</h5>
                    </div>

                    <div class="card-body">

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="MercadoLibreCategoryId" class="form-label fw-semibold">Categoría ML</label>
                                <input asp-for="MercadoLibreCategoryId" class="form-control" placeholder="Ejemplo: MLM189898" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="MercadoLibreListingTypeId" class="form-label fw-semibold">Tipo publicación</label>
                                <select asp-for="MercadoLibreListingTypeId" class="form-select">
                                    <option value="gold_special">Clásica</option>
                                    <option value="gold_pro">Premium</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="MercadoLibrePrice" class="form-label fw-semibold">Precio ML</label>
                                <input asp-for="MercadoLibrePrice" class="form-control" type="number" step="0.01" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="MercadoLibreStock" class="form-label fw-semibold">Stock ML</label>
                                <input asp-for="MercadoLibreStock" class="form-control" type="number" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="MercadoLibreCurrencyId" class="form-label fw-semibold">Moneda ML</label>
                                <input asp-for="MercadoLibreCurrencyId" class="form-control" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="MercadoLibreCondition" class="form-label fw-semibold">Condición</label>
                                <select asp-for="MercadoLibreCondition" class="form-select">
                                    <option value="new">Nuevo</option>
                                    <option value="used">Usado</option>
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Status" class="form-label fw-semibold">Estado interno</label>
                                <select asp-for="Status" class="form-select">
                                    <option value="Draft">Draft</option>
                                    <option value="Imported">Imported</option>
                                    <option value="NeedsReview">NeedsReview</option>
                                    <option value="ReadyToPublish">ReadyToPublish</option>
                                    <option value="Published">Published</option>
                                    <option value="PublishError">PublishError</option>
                                    <option value="Inactive">Inactive</option>
                                    <option value="OutOfStock">OutOfStock</option>
                                </select>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">
                        Cancelar
                    </a>

                    <button type="submit" class="btn btn-primary">
                        Guardar cambios
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}