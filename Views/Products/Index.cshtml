@model IEnumerable<MarketplaceSync.Web.Models.Product>

@{
    ViewData["Title"] = "Productos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-1">Productos</h1>
            <p class="text-muted mb-0">Productos importados o creados como borrador.</p>
        </div>

        <a asp-controller="Products" asp-action="CreateFromUrl" class="btn btn-primary">
            + Agregar producto por link
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <h5 class="fw-bold">Todavía no hay productos</h5>
                    <p class="text-muted">Agrega tu primer producto usando un link de Amazon, eBay o Mercado Libre.</p>
                    <a asp-controller="Products" asp-action="CreateFromUrl" class="btn btn-primary">
                        Agregar producto
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Imagen</th>
                                <th>Marketplace</th>
                                <th>Título</th>
                                <th>Source ID</th>
                                <th>Precio origen</th>
                                <th>URL</th>
                                <th>Status</th>
                                <th>Source Status</th>
                                <th>Creado</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>

                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl"
                                                 style="width:60px;height:60px;object-fit:cover;border-radius:10px;"
                                                 alt="Imagen producto" />
                                        }
                                        else
                                        {
                                            <div class="bg-light border rounded d-flex align-items-center justify-content-center"
                                                 style="width:60px;height:60px;">
                                                <span class="text-muted small">N/A</span>
                                            </div>
                                        }
                                    </td>

                                    <td>
                                        <span class="badge bg-dark">
                                            @(item.SourceMarketplace ?? "N/A")
                                        </span>
                                    </td>

                                    <td style="min-width:260px;">
                                        <div class="fw-semibold">
                                            @(item.Title ?? "Sin título")
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(item.Brand) || !string.IsNullOrWhiteSpace(item.Model))
                                        {
                                            <div class="text-muted small">
                                                @(item.Brand ?? "") @(item.Model ?? "")
                                            </div>
                                        }
                                    </td>

                                    <td>@(item.SourceProductId ?? "N/A")</td>

                                    <td>
                                        @if (item.SourcePrice.HasValue)
                                        {
                                            <span>@(item.SourceCurrency ?? "MXN") @item.SourcePrice.Value.ToString("N2")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </td>

                                    <td>
                                        <a href="@item.SourceUrl" target="_blank" class="text-decoration-none">
                                            Abrir link
                                        </a>
                                    </td>

                                    <td>
                                        <span class="badge bg-warning text-dark">
                                            @item.Status
                                        </span>
                                    </td>

                                    <td>
                                        <span class="badge bg-info text-dark">
                                            @(item.SourceStatus ?? "N/A")
                                        </span>
                                    </td>

                                    <td>@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>

                                    <td class="text-end">
                                        @if (!string.IsNullOrWhiteSpace(item.MercadoLibrePermalink))
                                        {
                                            <a href="@item.MercadoLibrePermalink"
                                               target="_blank"
                                               class="btn btn-outline-secondary btn-sm">
                                                Ver ML
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-controller="Products"
                                               asp-action="PublishToMercadoLibre"
                                               asp-route-id="@item.Id"
                                               class="btn btn-success btn-sm">
                                                Publicar ML
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>