@model IEnumerable<MarketplaceSync.Web.Models.Product>

@{
    ViewData["Title"] = "Productos";
}

<div class="container-fluid px-4 py-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h1 class="fw-bold mb-1">Productos</h1>
            <p class="text-muted mb-0">
                Administra productos importados desde eBay, Amazon o Mercado Libre.
            </p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="Products" asp-action="CreateFromUrl" class="btn btn-primary">
                + Agregar producto por link
            </a>

            <form asp-controller="Products" asp-action="RefreshAllSourceInfo" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary">
                    Actualizar todos
                </button>
            </form>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Total productos</div>
                    <div class="fs-3 fw-bold">@Model.Count()</div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">eBay</div>
                    <div class="fs-3 fw-bold">
                        @Model.Count(x => x.SourceMarketplace == "eBay")
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Amazon</div>
                    <div class="fs-3 fw-bold">
                        @Model.Count(x => x.SourceMarketplace == "Amazon")
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Publicados ML</div>
                    <div class="fs-3 fw-bold">
                        @Model.Count(x => !string.IsNullOrWhiteSpace(x.MercadoLibreItemId))
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0">Listado de productos</h5>
                <span class="text-muted small">
                    Última actualización: @DateTime.Now.ToString("yyyy-MM-dd HH:mm")
                </span>
            </div>
        </div>

        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5 px-3">
                    <div class="mb-3">
                        <span class="display-5">📦</span>
                    </div>
                    <h5 class="fw-bold">Todavía no hay productos</h5>
                    <p class="text-muted mb-4">
                        Agrega tu primer producto usando un link de eBay, Amazon o Mercado Libre.
                    </p>
                    <a asp-controller="Products" asp-action="CreateFromUrl" class="btn btn-primary">
                        Agregar producto
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 70px;">ID</th>
                                <th style="width: 90px;">Imagen</th>
                                <th>Producto</th>
                                <th style="width: 130px;">Marketplace</th>
                                <th style="width: 120px;">Precio</th>
                                <th style="width: 150px;">Stock</th>
                                <th style="width: 130px;">Estado</th>
                                <th style="width: 170px;">Última revisión</th>
                                <th style="width: 280px;">Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">
                                        @item.Id
                                    </td>

                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl"
                                                 alt="@item.Title"
                                                 class="rounded border"
                                                 style="width: 64px; height: 64px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="rounded border bg-light d-flex align-items-center justify-content-center"
                                                 style="width: 64px; height: 64px;">
                                                <span class="text-muted small">N/A</span>
                                            </div>
                                        }
                                    </td>

                                    <td>
                                        <div class="fw-semibold">
                                            @(string.IsNullOrWhiteSpace(item.Title) ? "Sin título" : item.Title)
                                        </div>

                                        <div class="text-muted small">
                                            @if (!string.IsNullOrWhiteSpace(item.Brand))
                                            {
                                                <span>Marca: @item.Brand</span>
                                            }

                                            @if (!string.IsNullOrWhiteSpace(item.Model))
                                            {
                                                <span class="ms-2">Modelo: @item.Model</span>
                                            }
                                        </div>

                                        <div class="text-muted small">
                                            Source ID: @(item.SourceProductId ?? "N/A")
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(item.SourceUrl))
                                        {
                                            <a href="@item.SourceUrl" target="_blank" class="small text-decoration-none">
                                                Abrir origen
                                            </a>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(item.MercadoLibrePermalink))
                                        {
                                            <span class="mx-1 text-muted">|</span>
                                            <a href="@item.MercadoLibrePermalink" target="_blank" class="small text-decoration-none">
                                                Ver en Mercado Libre
                                            </a>
                                        }
                                    </td>

                                    <td>
                                        @if (item.SourceMarketplace == "eBay")
                                        {
                                            <span class="badge bg-primary">eBay</span>
                                        }
                                        else if (item.SourceMarketplace == "Amazon")
                                        {
                                            <span class="badge bg-warning text-dark">Amazon</span>
                                        }
                                        else if (item.SourceMarketplace == "MercadoLibre")
                                        {
                                            <span class="badge bg-info text-dark">Mercado Libre</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                @(string.IsNullOrWhiteSpace(item.SourceMarketplace) ? "N/A" : item.SourceMarketplace)
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        @if (item.SourcePrice.HasValue)
                                        {
                                            <div class="fw-semibold">
                                                @item.SourcePrice.Value.ToString("N2")
                                            </div>
                                            <div class="text-muted small">
                                                @(item.SourceCurrency ?? "")
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </td>

                                    <td>
                                        @if (item.SourceStock.HasValue)
                                        {
                                            if (item.SourceStock.Value > 0)
                                            {
                                                <span class="badge bg-success">
                                                    @item.SourceStock.Value
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">
                                                    0
                                                </span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                N/A
                                            </span>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(item.SourceAvailabilityText))
                                        {
                                            <div class="small text-muted mt-1">
                                                @item.SourceAvailabilityText
                                            </div>
                                        }
                                    </td>

                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(item.MercadoLibreItemId))
                                        {
                                            <span class="badge bg-success">Publicado ML</span>
                                        }
                                        else if (item.Status == "Draft")
                                        {
                                            <span class="badge bg-warning text-dark">Draft</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                @(item.Status ?? "N/A")
                                            </span>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(item.SourceStatus))
                                        {
                                            <div class="small text-muted mt-1">
                                                @item.SourceStatus
                                            </div>
                                        }
                                    </td>

                                    <td>
                                        @if (item.LastSourceCheckAt.HasValue)
                                        {
                                            <div>
                                                @item.LastSourceCheckAt.Value.ToLocalTime().ToString("yyyy-MM-dd")
                                            </div>
                                            <div class="text-muted small">
                                                @item.LastSourceCheckAt.Value.ToLocalTime().ToString("HH:mm")
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin revisar</span>
                                        }
                                    </td>

                                    <td>
                                        <div class="d-flex flex-wrap gap-1">

                                            <a asp-controller="Products"
                                               asp-action="Details"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-secondary">
                                                Ver
                                            </a>

                                            <a asp-controller="Products"
                                               asp-action="Edit"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-dark">
                                                Editar
                                            </a>

                                        <form asp-controller="Products"
      asp-action="RefreshSource"
      asp-route-id="@item.Id"
      method="post"
      class="d-inline">
    @Html.AntiForgeryToken()

    <button type="submit" class="btn btn-sm btn-outline-primary">
        Actualizar info
    </button>
</form>
<a asp-controller="Products"
   asp-action="PublishToMercadoLibre"
   asp-route-id="@item.Id"
   class="btn btn-success">
    Publicar en Mercado Libre
</a>


                                            <form asp-controller="Products"
                                                  asp-action="Delete"
                                                  method="post"
                                                  class="d-inline"
                                                  onsubmit="return confirm('¿Seguro que deseas borrar este producto? Esta acción no elimina la publicación de Mercado Libre, solo borra el registro local.');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    Borrar
                                                </button>
                                            </form>

                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>